# Copy to .env and fill in. .env is gitignored.

# Environment: dev | staging | prod
ENV=dev
# DEBUG defaults to true when ENV=dev; set explicitly to override.
# DEBUG=true

PROJECT_NAME="Rapid Recovery"

# CORS: comma-separated origins, or leave empty to allow all ("*").
CORS_ORIGINS_STR=

# ---- MongoDB Atlas --------------------------------------------------------
# SRV connection string for your Atlas cluster (Connect -> Drivers).
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.xxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=homeward

# ---- Embeddings (Voyage AI) ----------------------------------------------
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3.5

# ---- Agent (Google ADK / Gemini) -----------------------------------------
# Google AI Studio API key for Gemini. Leave GOOGLE_GENAI_USE_VERTEXAI=false
# to use it; set it to true to authenticate through Vertex AI instead.
GOOGLE_API_KEY=
GOOGLE_GENAI_USE_VERTEXAI=false
GEMINI_MODEL=gemini-2.5-flash
# Voice (F6): a Gemini Live model advertising bidiGenerateContent. gemini-3.1
# connects on this key; the 2.5 native-audio models can return 1008. List models
# (supported_actions: bidiGenerateContent) to pick another id if needed.
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview

# ---- Scheduling (Cal.com, F4) --------------------------------------------
# CAL_API_BASE_URL must have no trailing characters (e.g. no trailing "=").
CAL_API_KEY=
CAL_API_BASE_URL=https://api.cal.com
CAL_SLOTS_API_VERSION=2024-09-04
CAL_BOOKINGS_API_VERSION=2026-02-25
CAL_USERNAME=
# CAL_EVENT_TYPE_SLUG is the event type SLUG (e.g. "homeward-booking"), NOT its
# numeric id. Passing the id makes /v2/slots return 404.
CAL_EVENT_TYPE_SLUG=
CLINIC_TIMEZONE=America/New_York

# ---- Auth (JWT) -----------------------------------------------------------
# MUST be overridden in production. Use a long random string (>= 32 chars).
JWT_SECRET_KEY=change-me-in-prod-change-me-in-prod-32chars-min
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---- Optional ops ---------------------------------------------------------
# SENTRY_DSN=
# API_ROOT_PATH=/
